{
  "name": "staygo-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Stay-Go backend (ride sharing + hostel maintenance)",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "maintenance:dev": "node --watch server.js",
    "maintenance:start": "node server.js",
    "seed": "node src/bootstrap/runSeed.js",
    "maintenance:seed": "node seed.js",
