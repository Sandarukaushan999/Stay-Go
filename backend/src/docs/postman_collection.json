{
    "info": {
        "name": "Stay & Go Backend API",
        "description": "Complete API collection for the Stay & Go hostel roommate matching system.\n\nSetup:\n1. Set the `baseUrl` variable to http://localhost:5000\n2. Run `npm run seed` to populate the database\n3. Set `studentId` variable to a seeded student _id\n4. All requests use x-student-id and x-role headers for dev auth",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000"
        },
        {
            "key": "studentId",
            "value": "PASTE_STUDENT_ID_HERE"
        },
        {
            "key": "studentId2",
            "value": "PASTE_SECOND_STUDENT_ID_HERE"
        },
        {
            "key": "requestId",
            "value": "PASTE_REQUEST_ID_HERE"
        },
        {
            "key": "roomId",
            "value": "PASTE_ROOM_ID_HERE"
        },
        {
            "key": "issueId",
            "value": "PASTE_ISSUE_ID_HERE"
        },
        {
            "key": "notificationId",
            "value": "PASTE_NOTIFICATION_ID_HERE"
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/health"
                    }
                }
            ]
        },
        {
            "name": "Student Profile",
            "item": [
                {
                    "name": "Create Profile",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-student-id",
                                "value": "{{studentId}}"
                            },
                            {
                                "key": "x-role",
                                "value": "student"
                            }
                        ],
                        "url": "{{baseUrl}}/api/students/profile",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"address\": \"123 Main St\",\n  \"email\": \"test.user@university.lk\",\n  \"whatsApp\": \"+94771111111\",\n  \"gender\": \"Male\",\n  \"age\": 21,\n  \"sleepSchedule\": \"EARLY_BIRD\",\n  \"cleanliness\": 4,\n  \"socialHabits\": \"MODERATE\",\n  \"studyHabits\": \"SILENT\"\n}"
                        }
                    }
                },
                {
                    "name": "Get My Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-student-id",
                                "value": "{{studentId}}"
                            },
                            {
                                "key": "x-role",
                                "value": "student"
                            }
                        ],
                        "url": "{{baseUrl}}/api/students/profile/me"
                    }
                },
                {
                    "name": "Update My Profile",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-student-id",
                                "value": "{{studentId}}"
                            },
                            {
                                "key": "x-role",
                                "value": "student"
                            }
                        ],
                        "url": "{{baseUrl}}/api/students/profile/me",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"cleanliness\": 5\n}"
                        }
                    }
                },
                {
                    "name": "Get Student By ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-student-id",
                                "value": "{{studentId}}"
                            },
                            {
                                "key": "x-role",
                                "value": "student"
                            }
                        ],
                        "url": "{{baseUrl}}/api/students/{{studentId2}}"
                    }
                }
            ]
        },
