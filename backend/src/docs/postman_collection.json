                            "raw": "{\n  \"availabilityStatus\": \"MAINTENANCE\"\n}"
                        }
                    }
                },
                {
                    "name": "Assign Student to Room (Admin)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "x-student-id",
                                "value": "{{studentId}}"
                            },
                            {
                                "key": "x-role",
                                "value": "admin"
                            }
                        ],
                        "url": "{{baseUrl}}/api/rooms/{{roomId}}/assign-student/{{studentId2}}"
